# ============================================================
# VRL Logistics - Environment Configuration Template
# ============================================================
# Copy this file to .env in the project root directory
# and fill in your actual values. NEVER commit .env to git!
# Add .env to your .gitignore file
# ============================================================

# ============================================================
# DJANGO SETTINGS
# ============================================================
DEBUG=True
SECRET_KEY=your-secret-key-here

# ============================================================
# TWILIO WHATSAPP CONFIGURATION
# ============================================================
# WhatsApp Business Messages via Twilio API
# Sign up for free at: https://www.twilio.com/console

# Your Twilio Account SID (find in Twilio Console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here

# Your Twilio Auth Token (find in Twilio Console)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# WhatsApp number provided by Twilio
# For testing: whatsapp:+14155238886 (Twilio sandbox)
# For production: your WhatsApp Business Number
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Enable/disable WhatsApp notifications (True/False)
WHATSAPP_NOTIFICATIONS_ENABLED=True

# WhatsApp message retry settings
WHATSAPP_RETRY_ATTEMPTS=3
WHATSAPP_RETRY_DELAY=5

# (Optional) Admin phone number for receiving alerts
# Format: +91XXXXXXXXXX (with country code)
ADMIN_PHONE_NUMBER=+919999999999

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Default is SQLite3 (db.sqlite3)
# Currently not using environment variables for DB in development
# For production, consider using PostgreSQL with environment variables

# ============================================================
# LOGGING
# ============================================================
# Log files will be created in: vrllogistics/logs/
# Available log files:
# - email.log      : All email notification activities
# - django.log     : Django framework warnings
# - error.log      : All application errors

# ============================================================
# ALLOWED HOSTS (Production)
# ============================================================
# For production, set this to your actual domain
# ALLOWED_HOSTS=example.com,www.example.com

# ============================================================
# SECURITY SETTINGS (Production)
# ============================================================
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
# 1. Copy this file to .env in the vrllogistics/ directory:
#    cp vrllogistics/.env.example vrllogistics/.env
#
# 2. Edit .env and fill in your Gmail credentials:
#    - EMAIL_HOST_USER: Your Gmail address
#    - EMAIL_HOST_PASSWORD: Your app-specific password (not regular password)
#
# 3. For Gmail Setup:
#    a. Login to https://myaccount.google.com/apppasswords
#    b. Select "Mail" and "Windows Computer" (or your device)
#    c. Google will generate a 16-character app-specific password
#    d. Copy this password into EMAIL_HOST_PASSWORD (spaces are normal)
#
# 4. Install python-decouple to use .env:
#    pip install python-decouple
#
# 5. Update settings.py to use python-decouple:
#    from decouple import config
#    EMAIL_HOST_USER = config('EMAIL_HOST_USER')
#    EMAIL_HOST_PASSWORD = config('EMAIL_HOST_PASSWORD')
#
# 6. Add .env to .gitignore to prevent accidental commits:
#    echo ".env" >> .gitignore
#
# ============================================================
# TROUBLESHOOTING EMAIL ISSUES
# ============================================================
# Common Email Problems and Solutions:
#
# 1. "SMTPAuthenticationError: Username and Password not accepted"
#    → Use app-specific password, not your regular Gmail password
#    → Verify EMAIL_HOST_USER matches your Gmail account
#    → Check that 2-Factor Authentication is enabled on your Gmail
#
# 2. "Connection refused" or "SMTP connection failed"
#    → Verify EMAIL_HOST and EMAIL_PORT are correct (smtp.gmail.com:587)
#    → Check that EMAIL_USE_TLS=True
#    → Verify your firewall allows outgoing SMTP connections
#
# 3. "Email sent but customer doesn't receive"
#    → Check spam/junk folder
#    → Verify recipient email address in database
#    → Check Gmail's Sent folder to see if email was actually sent
#
# 4. For development/testing only:
#    → Set EMAIL_BACKEND = 'django.core.mail.backends.console.EmailBackend'
#    → Emails will be printed to console instead of being sent
#
# ============================================================
# LOGGING CONFIGURATION
# ============================================================
# Email logs are stored in: vrllogistics/logs/email.log
# Check this file to debug email issues:
#
# Example commands:
# tail -f vrllogistics/logs/email.log              # View email logs in real-time
# grep "Error" vrllogistics/logs/email.log         # Find errors
# grep "assignment_accepted" vrllogistics/logs/email.log  # Find specific emails
#
# Log Format:
# ERROR 2024-01-15 18:45:30 utils 12345 67890 Email template not found: emails/test.html
#
# Field Breakdown:
# [LEVEL] [DATE] [TIME] [MODULE] [PROCESS_ID] [THREAD_ID] [MESSAGE]