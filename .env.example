# Django Security Configuration
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-keep-this-safe-and-unique

# Email Configuration (Gmail SMTP)
# For Gmail: Use an "App Password" (not your regular password)
# Enable 2FA on your Google Account and generate an app-specific password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
ADMIN_EMAIL=your-gmail@gmail.com
EMAIL_NOTIFICATIONS_ENABLED=True

# Django Settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
